{
  "name": "@opafex/mcp-servers",
  "version": "1.0.0",
  "private": true,
  "description": "Open-source MCP servers by Opafex",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/shared && npm run build -w packages/enrichment && npm run build -w packages/file-processor && npm run build -w packages/create-opafex-mcp",
    "test": "npm run test --workspaces --if-present",
    "clean": "rm -rf packages/*/dist",
    "typecheck": "npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/opafex/opafex-mcps.git"
  },
  "author": "Opafex",
  "license": "MIT"
}
